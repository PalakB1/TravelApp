// Travel company dashboard — data model
// Money is stored as whole rupees (Int). Currency symbol handled in the UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// An organization = one travel company using the platform. Every trip, customer,
// booking, payment and visa record is scoped to exactly one org (data isolation).
// New orgs self-serve sign up in status "pending" and stay dark until approved.
model Organization {
  id                 String   @id @default(cuid())
  name               String
  status             String   @default("pending") // pending | approved | rejected | suspended
  customTripsEnabled Boolean  @default(false) // "Custom trips" module — off by default, toggled by platform admin
  // Business / GST profile — printed on tax invoices (filled in Settings).
  legalName          String?
  gstin              String?
  gstAddress         String?
  gstState           String?
  gstStateCode       String?
  sacCode            String?  @default("998555") // SAC for tour-operator services
  invoiceNote        String?
  logo               String? // base64 data URL, shown on pay pages / receipts / invoices
  // Billing: 30-day trial → paid. plan = trial | pro | business (founders grandfathered to business).
  plan               String   @default("trial")
  trialEndsAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  trips        Trip[]
  customers    Customer[]
  activityLogs ActivityLog[]
  customTrips  CustomTrip[]
  expenses     Expense[]
}

// Costing ledger: any money YOU spend — supplier invoices, ground costs, fuel,
// salaries, marketing, software. Optionally tagged to a trip; untagged = general
// overhead. Each row can carry an uploaded invoice/receipt file (base64).
model Expense {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tripId      String? // null = general / overhead (not tied to a trip)
  trip        Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  // Optional finer target — the actual invoice for a specific hotel booking or
  // car (its stored cost is only a hold). tripId is kept in sync with these.
  hotelId     String?
  hotel       HotelBooking? @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  carId       String?
  car         Car?         @relation(fields: [carId], references: [id], onDelete: SetNull)
  date        DateTime     @default(now())
  category    String       @default("misc") // hotel | transport | flight | guide | permit | fuel | visa | marketing | salary | office | software | tax | misc
  payee       String? // vendor / who you paid
  amount      Int          @default(0) // rupees
  status      String       @default("paid") // paid | pending
  paymentMode String? // upi | cash | bank | card | other
  notes       String?
  fileName    String? // original name of the uploaded invoice
  fileType    String? // mime type
  fileData    String? // base64 data URL of the invoice/receipt
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime? // soft-delete: hidden everywhere, restorable from the recycle bin

  @@index([orgId])
  @@index([tripId])
  @@index([deletedAt])
}

// --- Custom trips module (bespoke, per-client à-la-carte itineraries) ---
// Separate from group Trip. A client's tailor-made plan = a list of line items
// (flight / hotel / transfer / …), each with its own cost + sell + GST toggle.
model CustomTrip {
  id          String    @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  clientName  String // denormalised for quick display/search
  clientPhone String?
  title       String    @default("Custom trip")
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("enquiry") // enquiry | confirmed | travelled | cancelled
  discount    Int       @default(0)
  gstRate     Int       @default(5)
  tcsRate     Int       @default(2)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt DateTime @updatedAt

  deletedAt   DateTime? // soft-delete: hidden everywhere, restorable from the recycle bin
  items    CustomItem[]
  payments CustomPayment[]

  @@index([orgId])
  @@index([customerId])
  @@index([deletedAt])
}

model CustomItem {
  id           String     @id @default(cuid())
  customTripId String
  trip         CustomTrip @relation(fields: [customTripId], references: [id], onDelete: Cascade)
  type         String     @default("other") // flight | hotel | transfer | activity | visa | insurance | rail | cruise | package | other
  description  String
  supplier     String?
  date         DateTime?
  qty          Int        @default(1)
  cost         Int        @default(0) // your cost per unit
  sell         Int        @default(0) // what you charge per unit
  taxable      Boolean    @default(true) // does this line attract GST + TCS
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt DateTime @updatedAt

  @@index([customTripId])
}

model CustomPayment {
  id           String     @id @default(cuid())
  customTripId String
  trip         CustomTrip @relation(fields: [customTripId], references: [id], onDelete: Cascade)
  amount       Int
  date         DateTime   @default(now())
  mode         String     @default("upi")
  note         String?

  @@index([customTripId])
}

// Gapless invoice serial counter, one row per org per financial year.
model InvoiceSeq {
  id     String @id @default(cuid())
  orgId  String
  fy     String // "2026-27"
  lastNo Int    @default(0)

  @@unique([orgId, fy])
}

// A marketing lead — an email captured on the landing page hero, even if the
// visitor never completes signup. Platform-level (not org-scoped).
model Lead {
  id        String   @id @default(cuid())
  email     String
  source    String?  @default("landing")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Activity log — a running history of what was added / changed / deleted,
// grouped by category so each menu (Hotels, Bookings, …) can show its own feed.
model ActivityLog {
  id          String        @id @default(cuid())
  orgId       String? // owning organization (backfilled to the default org)
  org         Organization? @relation(fields: [orgId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt DateTime @updatedAt
  category    String // hotel | booking | customer | payment | trip | car | team | admin
  action      String // added | updated | deleted | status | entered | exited
  summary     String // human-readable line
  href        String? // optional link target (e.g. /trips/abc)
  userId      String? // who performed it (denormalised — kept even if the user is later removed)
  userName    String? // snapshot of the actor's name
  actingAdmin Boolean       @default(false) // true when a platform admin did it while inside this org

  @@index([category, createdAt])
  @@index([orgId])
}

// A Schengen visa applicant who filled the trip's public visa form. Used to
// generate a cover letter + document checklist (trip dates/hotels merged in).
model VisaApplicant {
  id              String    @id @default(cuid())
  tripId          String
  trip            Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fullName        String // auto-composed "given surname" — kept for display + documents
  surname         String? // family / last name, exactly as in the passport
  givenName       String? // given / first name(s), exactly as in the passport
  dob             DateTime?
  placeOfBirth    String?
  nationality     String?   @default("Indian")
  maritalStatus   String?
  passportNo      String?
  passportIssue   DateTime?
  passportExpiry  DateTime?
  passportPlace   String?
  address         String?
  city            String?
  pin             String?
  phone           String?
  email           String?
  employmentType  String?   @default("employed") // employed | business | self | student | retired | homemaker | other
  occupation      String?
  employer        String?
  employerAddress String?
  gstNo           String? // for business owners
  income          String?
  funding         String?   @default("self") // self | sponsor
  sponsorName     String?
  sponsorRelation String?
  prevSchengen    String? // "no" or details (kept for back-compat)
  wantsLongTerm   Boolean   @default(false) // requesting a long-term multiple-entry visa (only if prior Schengen)
  travellingWith  String? // "alone" or names of companions
  travelHistory   String? // past international travel — strengthens ties
  dependents      String? // family staying home — ties to home
  investments     String? // property, FDs, MFs — financial roots
  notes           String?
  visaType        String?   @default("schengen") // schengen | generic — chosen when the link is shared
  visaCountry     String? // country name shown on the generic template (e.g. New Zealand)
  status          String    @default("collecting") // collecting | ready | appointment | submitted | approved | rejected
  appointmentAt   DateTime? // VFS appointment date/time
  createdAt       DateTime  @default(now())
  updatedAt DateTime @updatedAt
}

// Login accounts. Each user belongs to one organization (equal access within it).
// isPlatformAdmin = the platform owner (you) who approves orgs and can navigate in.
model User {
  id              String   @id @default(cuid())
  orgId           String? // owning organization (null only for the platform admin)
  org             Organization? @relation(fields: [orgId], references: [id])
  isPlatformAdmin Boolean  @default(false)
  // When true this member only sees the trips listed in tripAccess (else: all org trips).
  tripScoped      Boolean  @default(false)
  email           String   @unique
  name            String
  passwordHash    String
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripAccess      TripAccess[]

  @@index([orgId])
}

// Grants one member access to one trip (only meaningful when user.tripScoped).
model TripAccess {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
  @@index([userId])
  @@index([tripId])
}

// A trip = a packaged departure you sell
model Trip {
  id            String          @id @default(cuid())
  orgId         String? // owning organization (backfilled to the default org)
  org           Organization?   @relation(fields: [orgId], references: [id])
  name          String
  destination   String
  nights        Int             @default(0)
  days          Int             @default(0)
  departureDate DateTime?
  endDate       DateTime?
  capacity      Int             @default(0) // total seats
  maxPerRoom    Int             @default(2) // guests per room (double sharing), for the rooms-coverage check
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt DateTime @updatedAt

  variants      Variant[]
  inclusions    Inclusion[]
  bookings      Booking[]
  vendorBookings VendorBooking[]
  itinerary     Night[]
  cars          Car[]
  visaApplicants VisaApplicant[]
  access        TripAccess[]
  pendingPayments PendingPayment[]
  expenses      Expense[]
  deletedAt     DateTime? // soft-delete: hidden everywhere, restorable from the recycle bin

  @@index([orgId])
  @@index([deletedAt])
}

// One night/stop of a self-drive itinerary: a date + where the group sleeps.
// A night can hold several hotel bookings (e.g. the group split across 3 hotels).
// A night with no held/confirmed hotel is a gap the board flags red.
model Night {
  id        String         @id @default(cuid())
  tripId    String
  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order     Int            @default(0) // sequence within the trip
  date      DateTime?
  location  String // e.g. "Selfoss"
  notes     String?
  extra     Boolean        @default(false) // an add-on night outside the core itinerary (booked per customer need; no room requirement)
  createdAt DateTime       @default(now())
  updatedAt DateTime @updatedAt
  hotels    HotelBooking[]
}

// One hotel reserved for a night — rooms + cost + booking status.
model HotelBooking {
  id             String    @id @default(cuid())
  nightId        String
  night          Night     @relation(fields: [nightId], references: [id], onDelete: Cascade)
  hotelName      String
  rooms          Int       @default(0)
  cost           Int       @default(0) // total ₹ for this hotel for this night
  status         String    @default("hold") // unbooked | hold | final
  holdUntil      DateTime?
  source         String? // platform the hold/booking is on, e.g. "Booking.com"
  confirmationNo String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt DateTime @updatedAt
  expenses       Expense[]
}

// A car in the trip's self-drive fleet.
model Car {
  id             String    @id @default(cuid())
  tripId         String
  trip           Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  label          String    @default("Car") // "Car 1"
  carType        String? // "Dacia Duster"
  seats          Int       @default(0) // total people it holds, including the driver
  vendor         String?
  startDate      DateTime?
  endDate        DateTime?
  rentalCost     Int       @default(0) // ₹
  driverMode     String    @default("self") // self (client drives) | hired
  driverCost     Int       @default(0) // ₹, only when driverMode = hired
  driverNeedsStay Boolean  @default(false) // hired driver needs a room each night
  status         String    @default("hold") // hold | final
  holdUntil      DateTime?
  source         String?
  confirmationNo String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt DateTime @updatedAt
  expenses       Expense[]
}

// Price options for a trip (Deluxe, Standard, single/twin, with/without flights...)
model Variant {
  id        String    @id @default(cuid())
  tripId    String
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String
  sellPrice Int       @default(0) // per person price you charge
  occupancy String? // e.g. "twin share", "single"
  bookings  Booking[]
}

// Trip activities/extras (whale watching, blue lagoon…). Defaults are auto-added
// to every booking (cost only). Non-defaults are optional upsells (cost + charge).
// Prices are PER PERSON and snapshotted onto each booking when selected.
model Inclusion {
  id              String @id @default(cuid())
  tripId          String
  trip            Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name            String
  category        String @default("other") // hotel | flight | transfer | meal | tour | car | guide | other
  isDefault       Boolean @default(false)  // pre-selected on every booking
  cost            Int    @default(0) // your cost per person
  sellContribution Int   @default(0) // what you charge the customer per person (non-default upsells)
  taxable         Boolean @default(true)   // does the charge attract GST + TCS
  perPax          Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  selections      BookingInclusion[]
}

// An inclusion selected on a specific booking — price + date snapshotted so later
// price edits never change past bookings.
model BookingInclusion {
  id          String    @id @default(cuid())
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  inclusionId String?
  inclusion   Inclusion? @relation(fields: [inclusionId], references: [id], onDelete: SetNull)
  name        String     // snapshot
  cost        Int        @default(0) // per-person snapshot
  charge      Int        @default(0) // per-person snapshot (0 for defaults)
  taxable     Boolean    @default(true)
  isDefault   Boolean    @default(false)
  bookedAt    DateTime   @default(now())
}

// A person who books — reused across trips so you can see their full history.
model Customer {
  id        String    @id @default(cuid())
  orgId     String? // owning organization (backfilled to the default org)
  org       Organization? @relation(fields: [orgId], references: [id])
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
  customTrips CustomTrip[]
  deletedAt DateTime? // soft-delete: hidden everywhere, restorable from the recycle bin

  @@index([orgId])
  @@index([deletedAt])
}

// A customer booking on a trip
model Booking {
  id             String    @id @default(cuid())
  tripId         String
  trip           Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        Variant?  @relation(fields: [variantId], references: [id])
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  customerName   String // kept in sync with customer.name for quick display/search
  customerPhone  String?
  pax            Int       @default(1)

  // Package + invoice. Taxable subtotal = land + visa + flights − discount.
  // Invoice = taxable + GST + TCS + nonTaxable. GST/TCS pass through to govt.
  packageType    String    @default("land") // land | lva | full
  landAmount     Int       @default(0)
  visaAmount     Int       @default(0) // visa assistance service charge
  flightAmount   Int       @default(0)
  nonTaxable     Int       @default(0) // amount billed WITHOUT GST/TCS (e.g. embassy fee)
  gstRate        Int       @default(5) // percent
  tcsRate        Int       @default(2) // percent

  discount       Int       @default(0)
  discountReason String?
  notes          String? // free-text remarks (e.g. "1 night less", "Perlan paid extra")

  // GST tax-invoice number (gapless, per-org, per-financial-year) once generated
  invoiceNo      String?
  invoiceDate    DateTime?

  // GST + TCS remittance to the government
  taxRemitted    Boolean   @default(false)
  taxRemittedOn  DateTime?
  taxRemittedNote String? // challan / filing reference

  // Denormalised PER-PERSON inclusion sums (× pax at read time) — kept in sync
  // when selections change, so financial pages don't need to load the relation.
  inclCostPP     Int       @default(0) // your cost per person from selected inclusions
  inclTaxPP      Int       @default(0) // taxable charge per person (gets GST/TCS)
  inclNonTaxPP   Int       @default(0) // non-taxable charge per person
  travellerExtra Int       @default(0) // sum of per-traveller extra charges (flat, taxable)

  status         String    @default("confirmed") // enquiry | confirmed | travelled | cancelled
  createdAt      DateTime  @default(now())
  updatedAt DateTime @updatedAt
  payments       Payment[]
  travellers     Traveller[]
  inclusions     BookingInclusion[]
  pendingPayments PendingPayment[]
  deletedAt      DateTime? // soft-delete: hidden everywhere, restorable from the recycle bin

  @@index([deletedAt])
}

// An individual person on a booking (a family member / party member).
model Traveller {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name        String
  age         Int?
  extraCharge Int      @default(0) // extra billed to this specific person (supplement, upgrade…)
  extraNote   String? // why (e.g. "single room")
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Money received against a booking (advance, installments, balance)
model Payment {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount    Int
  date      DateTime @default(now())
  mode      String   @default("upi") // upi | card | cash | bank | other
  note      String?
}

// A payment a CUSTOMER self-reported via the public link — must be approved
// before it becomes a real Payment. Doesn't affect any balance until approved.
model PendingPayment {
  id         String   @id @default(cuid())
  // Matched to a booking when the payer's name resolves; else attached to the trip
  // (from the universal pay link) for the operator to link on approval.
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tripId     String?
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  amount     Int
  mode       String   @default("upi")
  date       DateTime @default(now())
  reference  String? // UTR / transaction id
  screenshot String? // base64 data URL of the proof image
  payerName  String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Operational bookings YOU make for a trip — hotels, cars, flights — and what they cost
model VendorBooking {
  id             String    @id @default(cuid())
  tripId         String
  trip           Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type           String    @default("activity") // activity | guide | permit | fuel | parking | flight | other
  vendorName     String
  detail         String?
  cost           Int       @default(0) // planned cost (your pre-trip estimate)
  actualCost     Int? // actual cost filled in after the trip; overrides planned in totals
  status         String    @default("pending") // pending | confirmed | paid
  confirmationNo String?
  date           DateTime?
  createdAt      DateTime  @default(now())
  updatedAt DateTime @updatedAt
}
